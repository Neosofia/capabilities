{
  "openapi": "3.0.3",
  "info": {
    "title": "Authorization Service API",
    "version": "0.3.0",
    "description": "Service contract for authorization entitlement evaluation and health checks."
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/capabilities": {
      "get": {
        "operationId": "listCapabilityNamespaces",
        "responses": {
          "200": {
            "description": "Capability namespaces available in the loaded policy bundle",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilityNamespacesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/capabilities/{namespace}": {
      "get": {
        "operationId": "getCapabilities",
        "parameters": [
          {
            "name": "namespace",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Cedar namespace for the principal (for example, ui)."
          }
        ],
        "responses": {
          "200": {
            "description": "Authorized entitlements for the current principal in the requested namespace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EntitlementsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown capability namespace",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status", "version"],
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string",
            "enum": ["ok"]
          },
          "version": {
            "type": "string",
            "description": "Service semver from pyproject at install/build time."
          }
        }
      },
      "EntitlementsResponse": {
        "type": "object",
        "additionalProperties": {
          "type": "boolean"
        }
      },
      "CapabilityNamespacesResponse": {
        "type": "object",
        "required": ["namespaces"],
        "additionalProperties": false,
        "properties": {
          "namespaces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "additionalProperties": false,
        "properties": {
          "error": {
            "type": "string",
            "enum": [
              "unauthenticated",
              "invalid_request",
              "forbidden",
              "authorization_unavailable",
              "internal_server_error",
              "method_not_allowed"
            ]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
